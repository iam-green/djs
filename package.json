{
  "name": "@iam-green/djs",
  "version": "0.0.1",
  "description": "",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev:babel": "babel src --extensions .ts --out-dir .babel --watch",
    "dev": "concurrently \"npm run dev:babel\" \"tsup .babel/index.ts --format cjs,esm --watch --dts\"",
    "build:babel": "babel src --extensions .ts --out-dir .babel",
    "build": "npm run build:babel && tsup .babel/index.ts --format cjs,esm --minify --clean --dts",
    "deploy:gha": "shx mkdir out && shx cp -r package.json LICENSE dist out/",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iam-green/djs.git"
  },
  "keywords": [],
  "author": "iam-green",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.28.6",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@swc/core": "^1.15.10",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.9",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.0",
    "rimraf": "^6.1.2",
    "shx": "^0.4.0",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
